{
  "name": "gemini-live-group-interpreter",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "bun test",
    "start": "bun run src/server/index.ts",
    "start:local": "bun run scripts/start-local.ts",
    "dev": "bun --filter '*' dev",
    "dev:api": "bun run src/server/index.ts",
    "dev:web": "vite --host 127.0.0.1",
    "build": "tsc --noEmit && vite build",
    "build:prod": "bun run build",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^1.27.0",
    "@vitejs/plugin-react": "^5.1.1",
    "elysia": "^1.4.16",
    "lucide-react": "^0.561.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "vite": "^7.3.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.5",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.9.3"
  }
}
